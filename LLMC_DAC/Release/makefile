# Tool invocations
LLMC_DAC.elf: $(OBJS) $(USER_OBJS) E:\Projects\You\LLMC\LLMC_DAC\app.ld makefile objects.list $(OPTIONAL_TOOL_DEPS)
	arm-none-eabi-gcc -o "LLMC_DAC.elf" @"objects.list" $(USER_OBJS) $(LIBS) -mcpu=cortex-m7 -T"E:\Projects\You\LLMC\LLMC_DAC\app.ld" --specs=nosys.specs -Wl,-Map="LLMC_DAC.map" -Wl,--gc-sections -static -L"E:\Projects\You\LLMC\LLMC_DAC\Middlewares\ST\ARM\DSP\Lib" -Wl,--no-wchar-size-warning  -mfpu=fpv5-d16 -mfloat-abi=hard -mthumb
	@echo 'Finished building target: $@'
	@echo ' '

default.size.stdout: $(EXECUTABLES) makefile objects.list $(OPTIONAL_TOOL_DEPS)
	arm-none-eabi-size  $(EXECUTABLES)
	@echo 'Finished building: $@'
	@echo ' '

LLMC_DAC.list: $(EXECUTABLES) makefile objects.list $(OPTIONAL_TOOL_DEPS)
	arm-none-eabi-objdump -h -S $(EXECUTABLES) > "LLMC_DAC.list"
	@echo 'Finished building: $@'
	@echo ' '

LLMC_DAC.hex: $(EXECUTABLES) makefile objects.list $(OPTIONAL_TOOL_DEPS)
	arm-none-eabi-objcopy  -O ihex $(EXECUTABLES) "LLMC_DAC.hex"
	@echo 'Finished building: $@'
	@echo ' '

# Other Targets
