/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */


  /* USER CODE END 1 */

  /* MPU Configuration--------------------------------------------------------*/
  MPU_Config();

  /* Enable I-Cache---------------------------------------------------------*/
  SCB_EnableICache();

  /* Enable D-Cache---------------------------------------------------------*/
  SCB_EnableDCache();

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

/* Configure the peripherals common clocks */
  PeriphCommonClock_Config();

  /* USER CODE BEGIN SysInit */
  // Load DTCM1_heap section from FLASH
  memcpy((void*)&_sDTCMRAM1_heap, (void*)&_siDTCMRAM1_heap, &_eDTCMRAM1_heap - &_sDTCMRAM1_heap);
  // Load DTCM2_heap section from FLASH
  memcpy((void*)&_sDTCMRAM2_heap, (void*)&_siDTCMRAM2_heap, &_eDTCMRAM2_heap - &_sDTCMRAM2_heap);
  // NOTE: CLEAN RAM_CD FOR USB usage
  USB_my_init_no_cache_memory();
  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_SAI2_Init();
  MX_DMA_Init();
  MX_SPI1_Init();
  MX_SDMMC1_SD_Init();
  MX_USART1_UART_Init();
  MX_I2C1_Init();
  MX_LTDC_Init();
  MX_FATFS_Init();
  MX_TIM2_Init();
  MX_ADC2_Init();
  MX_DMA2D_Init();
  /* USER CODE BEGIN 2 */

//  HAL_Delay(100); // kernel dead when HAL_Delay





  /* init: start LTDC */
  // start LCD back light
  set_display_enable(1);
  HAL_LTDC_Init(&hltdc);
  set_back_light(1);
  memset(framebuf1, 0xff, sizeof(framebuf1));

#if 0
  /* init: Audio DAC */
  // turn off NP power first
  NP_power_enable(0);

  pcm179x_hw_reset();
  // generate 1024 system clocks using blank
  HAL_SAI_Transmit(&hsai_BlockB2, (uint8_t*)bufDecoder, 1024, HAL_MAX_DELAY);
  pcm179x_init(&pcm179x);

  /* init: Audio ADC*/
  adcx120_reset(&adcx120);
  // generate 1024 system clocks using blank
  HAL_SAI_Receive(&hsai_BlockA2, (uint8_t*)bufEncoder, 1024, HAL_MAX_DELAY);
  adcx120_init(&adcx120);

  // set default sample rate and bit depth
  set_audio_sample_rate_and_bit_depth(DEFAULT_SAMPLE_RATE_T, DEFAULT_BIT_DEPTH);

  // apply audio connection and prepare transmissions
  // if enabled in config, will init all audio devices
  audio_connections_apply(cfg.audio_connections);
  USB_switch_to_configuration(USB_CFG_DESC_UAC1_0);
#endif
  /* init: USB configuration */
  USB_switch_to_configuration(USB_CFG_DESC_MASS_STORAGE);

  /* USER CODE END 2 */

  /* Init scheduler */
  osKernelInitialize();

  /* USER CODE BEGIN RTOS_MUTEX */

  /* add mutexes, ... */
  /* USER CODE END RTOS_MUTEX */

  /* USER CODE BEGIN RTOS_SEMAPHORES */
  /* add semaphores, ... */
  /* USER CODE END RTOS_SEMAPHORES */

  /* USER CODE BEGIN RTOS_TIMERS */
  /* start timers, add new ones, ... */
  /* USER CODE END RTOS_TIMERS */

  /* USER CODE BEGIN RTOS_QUEUES */
  /* add queues, ... */
  /* USER CODE END RTOS_QUEUES */

  /* Create the thread(s) */
  /* creation of defaultTask */
  defaultTaskHandle = osThreadNew(StartDefaultTask, NULL, &defaultTask_attributes);

  /* USER CODE BEGIN RTOS_THREADS */
  /* add threads, ... */

  lvgl_TimerHandle = osThreadNew(taskLVGLTimer, NULL, &taskLVGLTimer_attr);



  /* USER CODE END RTOS_THREADS */

  /* USER CODE BEGIN RTOS_EVENTS */
  /* add events, ... */
//  HAL_Delay(100);
  /* USER CODE END RTOS_EVENTS */

  /* Start scheduler */
  osKernelStart();

  /* We should never get here as control is now taken by the scheduler */
  /* Infinite loop */
  /* USER CODE BEGIN WHILE */


  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

/**
