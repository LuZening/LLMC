/* USER CODE BEGIN 4 */
char bufLVGLDebug[512] = {0};
/* LVGL timer for tasks. */
void taskLVGLTimer(void * argument)
{
  /* init: start lvgl */
  init_LVGL_GUI();
  bool calibrate_touchscreen = !cfg.TSCalibInfo.isCalibrated;

  start_LVGL_input_tasks(calibrate_touchscreen);
  if(!calibrate_touchscreen)
  {
	  lv_lock();
	  display_main_widgets();
	  lv_unlock();
  }

//  display_main_widgets();
  HAL_TIM_Base_Start_IT(&htim2);

  /* out put debug info */
  lv_obj_t *lbDebug = lv_label_create(lv_layer_sys());
  lv_obj_align(lbDebug, LV_ALIGN_TOP_LEFT, 0, 0);

//  lv_label_set_text_static(lbDebug, bufLVGLDebug);
  for(;;)
  {
	lv_lock();
	uint32_t time_till_next = lv_timer_handler();
	lv_unlock();
    osDelay(time_till_next);

  }
}


/* USER CODE END 4 */

/* USER CODE BEGIN Header_StartDefaultTask */
/**
  * @brief  Function implementing the defaultTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartDefaultTask */
void StartDefaultTask(void *argument)
{
  /* USER CODE BEGIN 5 */
  osDelay(pdMS_TO_TICKS(50)); // wait for SD card ready
  /* Init: mount SD card */
  SD_Driver.disk_initialize(0);
  osDelay(pdMS_TO_TICKS(50)); // wait for SD card ready
  FRESULT fr = f_mount(&SDFatFS, (const TCHAR*)SDPath,1);
  size_t lenRead;
  /* NOTE: SDMMC1 buf cannot be put at AHB SRAMS, DMA will halt */
  int ret;
//  ret = BSP_SD_ReadBlocks_DMA((uint32_t*)bufFileLoader, 0, 1);
//  osDelay(10);
  fr = f_open(&f, L"0:/test.txt", FA_READ);
  if(fr == FR_OK)
  {
	  f_read(&f, (uint8_t*)bufFile, 512, &lenRead);
	  f_close(&f);
	  strncpy(bufLVGLDebug, bufFile, 16);
  }
  else
  {
	  strcpy(bufLVGLDebug, "test failed");
  }
  /* Init: Load Config */
  fr = f_open(&f, FS_PATH_CONFIG_FILE, FA_READ);
  if(fr == FR_OK)
  {
	  f_read(&f, bufFile, sizeof(cfg), &lenRead);
	  memcpy(&cfg, bufFile, lenRead);
	  f_close(&f);
  }

  if((fr != FR_OK) || (!config_check_valid(&cfg)))
  {
	  init_config(&cfg);

  }


  /* init code for USB_DEVICE */
  MX_USB_DEVICE_Init();
  /* Infinite loop */
  for(;;)
  {
    osDelay(100);
    /* save config*/
    if(spSaveConfig)
    {
    	xSemaphoreTake(spSaveConfig, portMAX_DELAY );
		  fr = f_open(&f, FS_PATH_CONFIG_FILE, FA_WRITE);
		  if(fr == FR_OK)
		  {
			  xSemaphoreTake(mtxConfig, portMAX_DELAY);
			  memcpy(bufFile, &cfg, sizeof(cfg));
			  fr = f_open(&f, FS_PATH_CONFIG_FILE, FA_WRITE);
			  if(fr == FR_OK)
			  {
				  fr = f_write(&f, bufFile, sizeof(cfg), &lenRead);
				  if(fr == FR_OK)
					  f_close(&f);
			  }
			  xSemaphoreGive(mtxConfig);
		  }
    }
  }
  /* USER CODE END 5 */
}

